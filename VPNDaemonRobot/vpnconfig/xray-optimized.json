          "xver": 0,
          "serverNames": [
            "www.microsoft.com",
            "apple.com",
            "cloudflare.com",
            "google.com"
          ],
          "privateKey": "iJPbrf-Vv1pePgDQHroLYlnLu3-V6MbndZmJhK7zhns",
          "shortIds": [
            "",
            "a1b2c3d4",
            "12345678",
            "abcdef01"
          ]
        },
        "sockopt": {
          "tcpKeepAliveIdle": 30,
          "tcpKeepAliveInterval": 10,
          "tcpNoDelay": true,
          "acceptProxyProtocol": false,
          "mark": 0
