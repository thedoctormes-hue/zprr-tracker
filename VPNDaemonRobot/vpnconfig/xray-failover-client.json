{
  "log": {"loglevel": "warning"},
  "dns": {
    "servers": ["1.1.1.1", "1.0.0.1"],
    "queryStrategy": "UseIP"
  },
  "routing": {
    "rules": [
      {"type": "field", "protocol": ["bittorrent"], "outboundTag": "direct"},
      {"type": "field", "network": "tcp,udp", "balancerTag": "failover_lb"}
    ],
    "balancers": [
      {
        "tag": "failover_lb",
        "selector": ["warsaw", "florida"],
        "strategy": {
          "type": "leastLoad",
          "settings": {
            "maxRTT": "2s",
            "tolerance": 0.5
          }
        },
        "fallbackTag": "florida"
      }
    ],
    "domainMatcher": "hybrid"
  },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [{"id": "f1789628-34a3-4f37-abf9-14e4bd70a18e", "flow": "xtls-rprx-vision"}],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "www.microsoft.com:443",
          "serverNames": ["www.microsoft.com", "apple.com"],
          "privateKey": "kAdoyjUTciHFgoKM5awHXLl4OGGfC5ysoeZnTAIOgEo",
          "shortIds": [""]
        }
      },
      "sniffing": {"enabled": true, "destOverride": ["http", "tls", "quic"]}
    }
  ],
  "outbounds": [
    {
      "tag": "warsaw",
      "protocol": "vless",
      "settings": {
        "vnext": [{
          "address": "185.138.90.150",
          "port": 443,
          "users": [{"id": "f1789628-34a3-4f37-abf9-14e4bd70a18e", "encryption": "none", "flow": "xtls-rprx-vision"}]
        }]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "www.microsoft.com:443",
          "serverNames": ["www.microsoft.com"],
          "privateKey": "2GHw814dHN1bdgYrdl_oWFBzDmctPwzyl00B8Klk1XQ",
          "shortIds": [""]
        },
        "sockopt": {
          "dialerProxy": "warsaw-monitor"
        }
      }
    },
    {
      "tag": "florida",
      "protocol": "vless",
      "settings": {
        "vnext": [{
          "address": "104.253.1.210",
          "port": 10086,
          "users": [{"id": "f1789628-34a3-4f37-abf9-14e4bd70a18e", "encryption": "none", "flow": "xtls-rprx-vision"}]
        }]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "www.cloudflare.com:443",
          "serverNames": ["www.cloudflare.com"],
          "privateKey": "OC1kKNoZDAsaU3h3aLJ8D5PWMhCYAJck_Uz7VIqTymk",
          "shortIds": [""]
        },
        "sockopt": {
          "dialerProxy": "florida-monitor"
        }
      }
    },
    {"tag": "direct", "protocol": "freedom"},
    {"tag": "block", "protocol": "blackhole"}
  ],
  "burstObservatory": {
    "pingConfig": {
      "timeout": "2s",
      "interval": "30s",
      "sampling": 3,
      "destination": "http://www.gstatic.com/generate_204"
    },
    "subjectSelector": ["warsaw", "florida"]
  }
}