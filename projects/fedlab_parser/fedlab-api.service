[Unit]
Description=FedLab Semantic Search API
After=network.target qdrant.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/LabDoctorM/fedlab_parser
Environment="PATH=/root/LabDoctorM/venv/bin"
EnvironmentFile=/root/LabDoctorM/fedlab_parser/.env
ExecStart=/root/LabDoctorM/venv/bin/uvicorn api:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target