# OS Lab API Configuration Example
# Copy this file to .env and fill in your values

# Server hosts
WARSAW_HOST=your_warsaw_host_here
WARSAW_SYNCTHING=http://your_warsaw_syncthing:8384

FLORIDA_HOST=your_florida_host_here
FLORIDA_SYNCTHING=http://your_florida_syncthing:8384

RF_PROXY_HOST=your_rf_proxy_host_here
RF_PROXY_SYNCTHING=http://your_rf_proxy_syncthing:8384

# CORS origins (comma separated)
CORS_ORIGINS=http://your_domain:5173,http://localhost:5173
