  "errorStrategy": {
    "onEndpointError": "tryFallback",
    "onRateLimit": "exponentialBackoff",
    "onTimeout": "switchModel",
    "maxRetries": 3,
    "silentFallback": true
  },
  "commands": {
    "switchModel": {
      "enabled": true,
      "syntax": "/model <id> [duration=session|1h|until_restart]",
      "description": "Временно переключает модель для сессии/таймера"
    }
  },
  "mcpServers": {
    "context7": {
      "command": "/root/.nvm/versions/node/v22.22.1/bin/node",
      "args": [
        "/root/.nvm/versions/node/v22.22.1/lib/node_modules/@upstash/context7-mcp/dist/index.js"
      ],
      "timeout": 30000,
      "env": {
        "NODE_ENV": "production"
      },
      "description": "Actual docs for aiogram, FastAPI, React"
    },
    "fetch": {
      "command": "/root/.local/bin/uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "timeout": 30000,
      "description": "Reads any URLs, docs, APIs in chat"
    },
    "git": {
      "command": "/root/.local/bin/uvx",
      "args": [
        "mcp-server-git"
      ],
      "timeout": 30000,
      "env": {
        "GIT_ALLOW_PROTOCOL": "file:https:http:ssh:git"
      }
    },
    "memory": {
      "command": "/root/.nvm/versions/node/v22.22.1/bin/node",
      "args": [
        "/root/.nvm/versions/node/v22.22.1/lib/node_modules/@modelcontextprotocol/server-memory/dist/index.js",
