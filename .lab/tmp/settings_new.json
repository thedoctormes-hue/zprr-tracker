      ],
      "timeout": 30000,
      "description": "Knowledge graph from chat history"
    },
    "mermaid": {
      "command": "/root/.nvm/versions/node/v22.22.1/bin/node",
      "args": [
        "/root/.nvm/versions/node/v22.22.1/lib/node_modules/mcp-mermaid/build/index.js"
      ],
      "timeout": 30000,
      "description": "Generate Mermaid diagrams in chat"
    },
    "time": {
      "command": "/root/LabDoctorM/venv/bin/python",
      "args": [
        "-m",
        "mcp_server_time"
      ],
      "timeout": 30000,
      "description": "Timezone conversion and current time"
    },
    "filesystem": {
      "command": "/root/.nvm/versions/node/v22.22.1/bin/node",
      "args": [
        "/root/.nvm/versions/node/v22.22.1/lib/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "/root/LabDoctorM/"
      ],
      "timeout": 30000,
      "description": "Safe filesystem access to LabDoctorM projects"
    },
    "zavlab-vibecoding": {
      "command": "/root/LabDoctorM/venv/bin/python",
      "args": [
        "/root/LabDoctorM/infra/ZavLabVibecodingMCP/server.py"
      ],
      "timeout": 30000,
      "description": "Custom ZavLab vibecoding context server"
    }
  },
  "mcp": {
