[Unit]
Description=Protocol API (FastAPI)
After=network.target

[Service]
WorkingDirectory=/root/LabDoctorM/projects/telegram-bots/protocol
ExecStart=/root/LabDoctorM/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
EnvironmentFile=/root/LabDoctorM/projects/telegram-bots/protocol/.env

[Install]
WantedBy=multi-user.target
